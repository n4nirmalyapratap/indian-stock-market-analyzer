modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Python Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Stock Market Frontend"

[[workflows.workflow]]
name = "Python Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/python-backend && PORT=8090 python run.py"
waitForPort = 8090

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Stock Market Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/ PORT=3002 pnpm --filter @workspace/nestjs-backend-placeholder run dev"
waitForPort = 3002

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8090
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]
