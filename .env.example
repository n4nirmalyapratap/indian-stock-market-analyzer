# ── Indian Stock Market Analyzer — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up --build -d
# ─────────────────────────────────────────────────────────────────────────────


# ── Clerk Authentication (user app) ──────────────────────────────────────────
# Get these from https://dashboard.clerk.com → Your App → API Keys
#
# CLERK_PUBLISHABLE_KEY  — used by Python backend to fetch JWKS and verify JWTs
# CLERK_SECRET_KEY       — used to call Clerk REST API (e.g. list users in admin)
# VITE_CLERK_PUBLISHABLE_KEY — baked into user frontend JS bundle at build time
# All three should be the same pk_*/sk_* key pair from your Clerk dashboard.

CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here


# ── Admin Dashboard Credentials ───────────────────────────────────────────────
# Used by /api/admin/login. Only this user can log into the admin panel.
# No registration flow — change these to something strong before deploying.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password


# ── Optional: Telegram Bot ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram. Leave empty to disable.

TELEGRAM_BOT_TOKEN=


# ── Optional: WhatsApp (Twilio) ───────────────────────────────────────────────
# Requires a Twilio account with WhatsApp sandbox or approved number.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
