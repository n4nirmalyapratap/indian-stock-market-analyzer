# ── Indian Stock Market Analyzer — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required: Clerk Authentication ──────────────────────────────────────────
# Find these in the Auth pane in your Replit workspace (Configure tab),
# or from your Clerk dashboard at clerk.com → API Keys.
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# ── Required: Session ────────────────────────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_random_32char_secret

# ── Optional: Telegram Bot ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Optional: Twilio (WhatsApp) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
