# ── Indian Stock Market Analyzer — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up --build -d
# ─────────────────────────────────────────────────────────────────────────────


# ── Custom Auth — JWT Secret (REQUIRED) ──────────────────────────────────────
# Used to sign email+password login tokens (HS256 JWT, 30-day expiry).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be long (32+ chars), random, and kept private.

SESSION_SECRET=replace_with_a_long_random_secret_here


# ── Admin Dashboard Credentials (REQUIRED) ───────────────────────────────────
# Used by /api/admin/login. Only this one account can log into the admin panel.
# No registration flow — set something strong before deploying.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password


# ── Optional: WhatsApp alerts via Twilio ─────────────────────────────────────
# Requires a Twilio account with a WhatsApp sandbox or approved number.
# Leave empty to disable the WhatsApp webhook endpoint.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=


# ── Optional: Telegram bot alerts ────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, paste the token below.
# Leave empty to disable — the admin Overview page shows "Telegram: not configured".

TELEGRAM_BOT_TOKEN=


# ── Optional: WhatsApp webhook toggle ────────────────────────────────────────
# Set to "true" to enable the WhatsApp webhook endpoint (/api/whatsapp/webhook).
# Requires TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN to also be set.

WHATSAPP_ENABLED=false
