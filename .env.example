# ── Indian Stock Market Analyzer — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up --build -d
# ─────────────────────────────────────────────────────────────────────────────


# ── Custom Auth — JWT Secret (REQUIRED) ──────────────────────────────────────
# Used to sign email+password login tokens (HS256 JWT, 30-day expiry).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be long (32+ chars), random, and kept private.

SESSION_SECRET=replace_with_a_long_random_secret_here


# ── Admin Dashboard Credentials (REQUIRED) ───────────────────────────────────
# Used by /api/admin/login. Only this one account can log into the admin panel.
# No registration flow — set something strong before deploying.

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password


# ── Clerk Authentication (optional — enables Google OAuth) ───────────────────
# If set, the user app shows "Continue with Google" alongside email+password.
# If left empty, the app works with email+password auth only.
#
# Get these from https://dashboard.clerk.com → Your App → API Keys
#   CLERK_PUBLISHABLE_KEY  — backend uses this to fetch JWKS for JWT verification
#   CLERK_SECRET_KEY       — backend uses this to call Clerk REST API (admin user list)
#   VITE_CLERK_PUBLISHABLE_KEY — baked into the user-app JS bundle at build time
# All three should come from the same Clerk app.

CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here


# ── Optional: Telegram Bot ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram. Leave empty to disable.

TELEGRAM_BOT_TOKEN=


# ── Optional: WhatsApp (Twilio) ───────────────────────────────────────────────
# Requires a Twilio account with WhatsApp sandbox or approved number.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
